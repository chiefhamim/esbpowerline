// ESB PowerLine Prisma Schema
// Ported & extended from the excellent legacy datastore.js models + BD_PWR_TREE power data models.
// PostgreSQL + full feature parity for Articles, Users/Roles/Permissions, Magazine, Media, Comments, Analytics, + interactive Grid data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS + AUTH + ROLES (port of datastore Users + ROLES + hasPermission)
// ============================================
model User {
  id              String     @id @default(cuid())
  supabaseUserId  String?    @unique
  name            String
  email           String     @unique
  phone           String?    @unique
  passwordHash    String
  role          Role       @default(AUTHOR)
  pendingName   String?
  avatar        String?
  bio           String?
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  articlesCount Int        @default(0)
  totalViews    Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  articles        Article[]
  receivedNotices EditorialNotice[] @relation("ReceivedNotices")
  sentNotices     EditorialNotice[] @relation("SentNotices")
  savedItems      SavedItem[]
  memberDownloads      MemberDownload[]
  comments             Comment[]
  gridSubscription     MemberGridSubscription?
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
  CONTRIBUTOR
  SUBSCRIBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// ============================================
// ARTICLES (core of the news portal; rich parity with datastore)
// ============================================
model Article {
  id          String          @id @default(cuid())
  title       String
  shortTitle  String?
  slug        String          @unique
  excerpt     String?
  content     String          // TipTap JSON or sanitized HTML
  authorId    String
  author      User            @relation(fields: [authorId], references: [id])
  publishedAt DateTime?
  status      ArticleStatus   @default(DRAFT)
  category    String
  categoryId  String?
  categoryRef Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  imageUrl    String?
  imageCredit String?
  titleBn     String?
  excerptBn   String?
  contentBn   String?

  readTime    Int             @default(1)
  views       Int             @default(0)
  likes       Int             @default(0)
  isFeatured  Boolean         @default(false)
  isBreaking  Boolean         @default(false)
  isPinned    Boolean         @default(false)
  isTrending  Boolean         @default(false)
  postAsNewsDesk Boolean      @default(false)
  tags        Json?           // array of strings stored as JSON (sqlite does not support scalar lists natively in this setup)
  seo         Json?           // { metaTitle, metaDescription, focusKeyword, ogImage }
  collaboratorIds Json?       // array of user IDs
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  version     Int             @default(1)
  locale      String          @default("en")
  /** Private editor trash — hidden from admins; purged after 7 days */
  editorTrash Boolean         @default(false)
  trashedAt   DateTime?

  revisions Revision[]
  notices   EditorialNotice[]
  viewEvents ArticleView[]
}

/** Append-only pageview ledger — Article.views increments only via recordArticleView(). */
model ArticleView {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  visitorKey  String
  dedupBucket String   @default("")
  viewedAt    DateTime @default(now())
  referrer    String?

  @@unique([articleId, visitorKey, dedupBucket])
  @@index([articleId, viewedAt])
  @@index([visitorKey, articleId])
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
  TRASH
}

// ============================================
// CATEGORIES (exact legacy 10)
// ============================================
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon          String?
  iconImageUrl  String?
  color       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  articles    Article[]
}

// ============================================
// EDITORIAL NOTICES (admin → author requests & alerts)
// ============================================
model EditorialNotice {
  id          String                @id @default(cuid())
  type        EditorialNoticeType
  message     String
  status      EditorialNoticeStatus @default(PENDING)
  articleId   String?
  article     Article?              @relation(fields: [articleId], references: [id], onDelete: SetNull)
  recipientId String
  recipient   User                  @relation("ReceivedNotices", fields: [recipientId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User                  @relation("SentNotices", fields: [senderId], references: [id], onDelete: Cascade)
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  trashedAt   DateTime?
}

enum EditorialNoticeType {
  REVISION_REQUEST
  REVIEW_SUBMISSION
  REVIEW_APPROVED
  CONTENT_REMOVED
  CATEGORY_CHANGED
  ADMIN_NOTE
}

enum EditorialNoticeStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

// ============================================
// REVISIONS (article history)
// ============================================
model Revision {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  userId    String?
  note      String?
  createdAt DateTime @default(now())
}

// ============================================
// MEDIA (images, PDFs for articles + magazine)
// ============================================
model Media {
  id           String   @id @default(cuid())
  name         String
  url          String
  type         String   // image | pdf | video
  mimeType     String?
  size         Int?
  altText      String?
  caption      String?
  uploadedById String?
  usedIn       Json?     // array of ids stored as JSON for sqlite compatibility
  createdAt    DateTime @default(now())
}

// ============================================
// COMMENTS (moderation)
// ============================================
model Comment {
  id          String        @id @default(cuid())
  articleId   String
  parentId    String?
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName  String
  authorEmail String?
  content     String
  status      CommentStatus @default(PENDING)
  likes       Int           @default(0)
  createdAt   DateTime      @default(now())
}

model SavedItem {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType  SavedItemType
  targetId  String
  createdAt DateTime      @default(now())

  @@unique([userId, itemType, targetId])
}

enum SavedItemType {
  ARTICLE
  MAGAZINE
}

model MemberDownload {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  fileUrl   String?
  createdAt DateTime @default(now())
}

/** Paid grid archive subscription — payment webhook activates plan. */
model MemberGridSubscription {
  id        String                 @id @default(cuid())
  userId    String                 @unique
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      GridSubscriptionPlan   @default(NONE)
  status    GridSubscriptionStatus @default(PENDING)
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

enum GridSubscriptionPlan {
  NONE
  PLAN_499
  PLAN_999
}

enum GridSubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum CommentStatus {
  APPROVED
  PENDING
  SPAM
  TRASH
}

// ============================================
// MAGAZINE ISSUES
// ============================================
model MagazineIssue {
  id           String   @id @default(cuid())
  title        String
  issueDate    DateTime
  coverUrl     String?
  pdfUrl       String?
  summary      String?
  status       String   @default("published")
  articleLinks Json?     // array of article slugs/ids stored as JSON (sqlite compatible)
  createdAt    DateTime @default(now())
}

// ============================================
// POWER GRID / DATA REPORTS (unified from BD_PWR_TREE)
// ============================================
model Node {
  id                String    @id @default(cuid())
  label             String
  designation       String
  category          String
  status            String    @default("normal")
  websiteUrl        String?
  capacityData      String?
  nodeColor         String?
  textColor         String    @default("#e2e8f0")
  x                 Float     @default(0)
  y                 Float     @default(0)
  manualX           Float?
  manualY           Float?
  useManualOverride Boolean   @default(false)
  parentId          String?
  icon              String?
  kpiValue          String?
  kpiUnit           String?
  lastUpdated       String?
  description       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  parent   Node?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Node[] @relation("NodeHierarchy")

  edgesFrom Edge[] @relation("EdgeSource")
  edgesTo   Edge[] @relation("EdgeTarget")
}

model Edge {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  edgeColor String   @default("#64748b")
  edgeStyle String   @default("solid")
  label     String?
  flowVolume Float?
  flowType  String?
  animated  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source Node @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Node @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model DashboardStat {
  id                String    @id @default(cuid())
  statName          String    @unique
  value             Float     @default(0)
  calculatedValue   Float?
  isManualOverride  Boolean   @default(false)
  unit              String?
  formula           String?
  lastCalculated    DateTime?
  source            String?
  sourceUrl         String?
  lastVerified      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================
// SUPPORTING (Logs, Newsletter, Ads, Settings, Pages)
// ============================================
model AuditLog {
  id          String   @id @default(cuid())
  type        String
  message     String
  userId      String?
  undoPayload String?
  // user relation removed to satisfy Prisma validation in current dev setup
  timestamp   DateTime @default(now())
}

model NewsletterSub {
  id            String   @id @default(cuid())
  email         String   @unique
  subscribedAt  DateTime @default(now())
  status        String   @default("active")
}

model Ad {
  id         String   @id @default(cuid())
  name       String
  position   String
  content    String
  link       String   @default("#")
  isActive   Boolean  @default(true)
  impressions Int     @default(0)
  clicks     Int      @default(0)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// (Pages model can be added later for About/Contact custom content)

// ============================================
// PROFILE (Supabase auth.users mirror — id matches UUID from auth.users)
// ============================================
model Profile {
  id        String   @id // matches Supabase auth.users UUID exactly
  fullName  String?
  role      String   @default("MEMBER")
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// TAGS (normalized tag lookup)
// ============================================
model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
}

// ============================================
// TICKER ITEMS (live market/news ticker on homepage)
// ============================================
model TickerItem {
  id        String   @id @default(cuid())
  text      String
  url       String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ============================================
// NOTIFICATIONS (user-targeted alerts)
// ============================================
model Notification {
  id        String   @id @default(cuid())
  userId    String   // Profile.id
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================
// BOOKMARKS (user article saves — composite key)
// ============================================
model Bookmark {
  userId    String
  articleId String
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

// ============================================
// ARTICLE HISTORY (status transition log)
// ============================================
model ArticleHistory {
  id         String   @id @default(cuid())
  articleId  String
  fromStatus String
  toStatus   String
  changedBy  String   // Profile.id
  comment    String?
  createdAt  DateTime @default(now())
}

// ============================================
// CONTACT MESSAGES (user feedback & contact queries)
// ============================================
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?  // Phone Number (WhatsApp)
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

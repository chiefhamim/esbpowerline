# ESB PowerLine — Environment (copy to .env.local for local dev)

# ── Local dev (SQLite) ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
# Must match prisma/schema.prisma `provider` after `prisma generate` (default: sqlite)
PRISMA_SCHEMA_PROVIDER=sqlite

# ── Production deploy (Supabase Postgres) ───────────────────────────
# Set on Vercel + locally when running prod migrations/seed:
#   PRISMA_SCHEMA_PROVIDER=postgresql
#   PRISMA_MIGRATIONS_DIR=prisma/migrations_postgresql
# Deploy schema:  npm run db:deploy:prod
# Bootstrap data:  ALLOW_PRODUCTION_SEED=true MASTER_ADMIN_PASSWORD=... npm run db:seed:prod
# Local sqlite dev continues with PRISMA_SCHEMA_PROVIDER=sqlite and `npm run db:push`

# ── Vercel / production (Supabase Postgres) ─────────────────────────
# Get both URLs from: Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL  = Transaction pooler (port 6543) — used by the app at runtime
#   Mode: Transaction | URI format
#   Example:
#   postgresql://postgres.sxgokpmrbgdndstygapc:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL    = Direct connection (port 5432) — REQUIRED for Prisma migrate deploy on Vercel
#                 (DATABASE_URL pooler :6543 will hang on migrations if DIRECT_URL is missing)
#   Mode: Session | URI format  (or use the "Direct connection" string)
#   Example:
#   postgresql://postgres.sxgokpmrbgdndstygapc:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
#
# IMPORTANT: username must be postgres.[project-ref] (not just "postgres") for pooler URLs.
# If your password has special characters (@, #, %, etc.) URL-encode them.
# DATABASE_URL="postgresql://postgres.sxgokpmrbgdndstygapc:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.sxgokpmrbgdndstygapc:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Auth handoff + session signing (generate: openssl rand -base64 32)
AUTH_SECRET="your-super-secret-here-change-in-prod"

# Supabase Auth (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Legacy alias (optional if publishable key is set):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Public bucket for CMS media uploads (run supabase/setup-storage.sql once)
# SUPABASE_STORAGE_BUCKET=media

# Custom production domain for cross-subdomain auth cookies (e.g. esbpowerline.com).
# Leave empty on *.vercel.app — all panels (/admin, /cms, /members) live on one URL.
NEXT_PUBLIC_APP_DOMAIN=""

# Local-only demo password for prisma/seed.ts — never commit the real value
SEED_DEMO_PASSWORD=

# Required to run prisma/seed or supabase seed scripts against production (default: blocked)
# ALLOW_PRODUCTION_SEED=true

# Bearer token for GET /api/cron/publish-scheduled (Vercel cron or external scheduler)
# CRON_SECRET=

# Master admin bootstrap password (admin@esbpowerline.com) — used only when account does not exist yet
# MASTER_ADMIN_PASSWORD=

# ── QA / dry-run flags (local only — never enable in production) ─────
# Render /admin/analytics charts with fixed mock data (no DB reads)
# NEXT_PUBLIC_MOCK_ANALYTICS=true
# Intercept CMS article saves — log JSON payload, skip Supabase INSERT
# NEXT_PUBLIC_MOCK_ARTICLE_SUBMIT=true
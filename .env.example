# ESB PowerLine — Environment (copy to .env.local)
# PostgreSQL (Neon recommended for Vercel)
DATABASE_URL="postgresql://user:pass@host:5432/esbpowerline?schema=public"

# Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET="your-super-secret-here-change-in-prod"

# Optional: Vercel Blob for real image/PDF uploads (Phase 5+)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# For development only demo seeds (do not use in prod)
# NEXTAUTH_URL="http://localhost:3000"

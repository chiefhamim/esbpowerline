# ESB PowerLine — Environment (copy to .env.local)
# PostgreSQL (Neon recommended for Vercel)
DATABASE_URL="postgresql://user:pass@host:5432/esbpowerline?schema=public"

# Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET="your-super-secret-here-change-in-prod"

# Supabase (https://supabase.com/dashboard — project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Legacy alias (optional if publishable key is set):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Custom production domain for cross-subdomain auth cookies (e.g. esbpowerline.com).
# Leave empty on *.vercel.app — all panels (/admin, /cms, /members) live on one URL.
# Do NOT set APP_SURFACE on Vercel (that is only for local npm run dev:all).
NEXT_PUBLIC_APP_DOMAIN=""

# Optional: Vercel Blob for real image/PDF uploads (Phase 5+)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# For local dev only — do NOT set AUTH_URL or NEXTAUTH_URL on Vercel (*.vercel.app).
# Wrong values (e.g. http://localhost:3000) cause login redirect loops in production.
# NEXTAUTH_URL="http://localhost:3000"
# Local-only demo password for prisma/seed.ts — never commit the real value
SEED_DEMO_PASSWORD=

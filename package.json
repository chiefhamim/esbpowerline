{
  "name": "esbpowerline",
  "version": "0.1.0",
  "private": true,
  "description": "ESB PowerLine — Bangladesh's premier energy & power sector news portal, magazine, CMS and full Admin dashboard. Next.js 15 + Prisma + TypeScript + shadcn/ui.",
  "scripts": {
    "dev": "next dev",
    "dev:public": "APP_SURFACE=public next dev -p 3000",
    "dev:cms": "APP_SURFACE=cms next dev -p 3001",
    "dev:admin": "APP_SURFACE=admin next dev -p 3002",
    "dev:all": "concurrently -k -n public,cms,admin -c blue,green,magenta \"npm:dev:public\" \"npm:dev:cms\" \"npm:dev:admin\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.511.0",
    "next": "^15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.3.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

{
  "name": "esbpowerline",
  "version": "0.1.0",
  "private": true,
  "description": "ESB PowerLine — Bangladesh's premier energy & power sector news portal, magazine, CMS and full Admin dashboard. Next.js 15 + Prisma + TypeScript + shadcn/ui.",
  "scripts": {
    "dev": "next dev",
    "dev:fast": "next dev",
    "dev:clean": "rm -rf .next .next-public .next-cms .next-admin",
    "dev:public": "cross-env APP_SURFACE=public next dev --webpack -p 3000",
    "dev:cms": "cross-env APP_SURFACE=cms next dev --webpack -p 3001",
    "dev:admin": "cross-env APP_SURFACE=admin next dev --webpack -p 3002",
    "dev:warmup": "node scripts/dev-warmup.mjs",
    "dev:all": "concurrently -n public,cms,admin,warmup -c blue,green,magenta,yellow --restart-tries 5 --restart-after 3000 \"npm:dev:public\" \"npm:dev:cms\" \"npm:dev:admin\" \"npm:dev:warmup\"",
    "build": "node scripts/sync-prisma-provider.mjs && prisma generate && next build",
    "build:vercel": "cross-env PRISMA_SCHEMA_PROVIDER=postgresql node scripts/sync-prisma-provider.mjs && prisma generate && cross-env PRISMA_SCHEMA_PROVIDER=postgresql PRISMA_MIGRATIONS_DIR=prisma/migrations_postgresql node scripts/migrate-deploy-prod.mjs && cross-env PRISMA_SCHEMA_PROVIDER=postgresql next build",
    "db:deploy": "prisma migrate deploy",
    "db:deploy:prod": "cross-env PRISMA_SCHEMA_PROVIDER=postgresql node scripts/sync-prisma-provider.mjs && cross-env PRISMA_SCHEMA_PROVIDER=postgresql PRISMA_MIGRATIONS_DIR=prisma/migrations_postgresql node scripts/migrate-deploy-prod.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node scripts/sync-prisma-provider.mjs && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed-production.ts",
    "supabase:seed-staff": "tsx scripts/seed-supabase-staff.ts",
    "supabase:seed-member": "node scripts/seed-supabase-member.mjs",
    "bootstrap:prod": "cross-env PRISMA_SCHEMA_PROVIDER=postgresql node scripts/bootstrap-production.mjs",
    "import:news": "cross-env PRISMA_SCHEMA_PROVIDER=postgresql tsx scripts/import-esbpowerline-news.ts",
    "import:news:prod": "cross-env PRISMA_SCHEMA_PROVIDER=postgresql ALLOW_PRODUCTION_SEED=true tsx scripts/import-esbpowerline-news.ts",
    "import:news:local": "cross-env PRISMA_SCHEMA_PROVIDER=sqlite DATABASE_URL=file:./dev.db tsx scripts/import-esbpowerline-news.ts",
    "env:pull": "node scripts/env-pull-vercel.mjs",
    "setup:agents": "scripts/setup-agent-integrations.cmd",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:qa": "vitest run lib/test/role-isolation.test.ts lib/test/article-submit.test.ts lib/test/staff-accounts.test.ts lib/test/env-auth.test.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-popover": "^1.1.17",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tiptap/extension-horizontal-rule": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.511.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.3.3",
    "postcss": "^8.4.49",
    "supabase": "^2.107.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vercel": "^54.14.2",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "better-sqlite3@12.11.1": true,
    "prisma@7.8.0": true
  }
}
